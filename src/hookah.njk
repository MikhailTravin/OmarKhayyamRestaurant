<!DOCTYPE html>
<html lang="ru">

<head>
    <title>Кальянная</title>
    {% include 'blocks/head.njk' %}
</head>

<body class="preload mp">
    <div class="main-wrapper-outer">
        <header class="header">
            <div class="container">
                <div class="header__content">
                    <a href="./" class="header__logo">
                        <img src="img/icons/logo1.svg" alt="">
                    </a>
                    <div class="header__body">
                        <ul>
                            <li>
                                <a href="index.html">Главная</a>
                            </li>
                            <li>
                                <a href="menu.html">Меню</a>
                            </li>
                            <li>
                                <a href="hookah.html" class="active">Кальянная</a>
                            </li>
                            <li>
                                <a href="vacancies.html">Вакансии</a>
                            </li>
                            <li>
                                <a href="contacts.html">Контакты</a>
                            </li>
                        </ul>
                    </div>
                    <div class="header__right">
                        <div data-da=".header__body, 1200, last" class="header__contacts">
                            <div class="header__contact">
                                <div class="header__icon">
                                    <svg aria-hidden="true" width="15" height="19">
                                        <use xlink:href="img/sprite.svg#location"></use>
                                    </svg>
                                </div>
                                <div class="header__item">
                                    <span>Местоположение</span>
                                    <div class="header__title">
                                        ТЦ Экспобел
                                    </div>
                                </div>
                            </div>
                            <div class="header__contact">
                                <div class="header__icon">
                                    <svg aria-hidden="true" width="18" height="18">
                                        <use xlink:href="img/sprite.svg#phone"></use>
                                    </svg>
                                </div>
                                <div class="header__item">
                                    <a href="tel:375295254950" class="header__title">
                                        +375 29 525 49 50
                                    </a>
                                    <span>с 8:00 до 00:00</span>
                                </div>
                            </div>
                        </div>
                        <a href="./" data-popup="#forms" class="btn">
                            <span>Бронирование</span>
                        </a>
                        <button type="button" class="header__burger">
                            <span class="icon-menu">
                                <span></span>
                            </span>
                        </button>
                    </div>
                </div>
            </div>
        </header>
        <main class="main">

            <div class="bg">
                <img src="img/bg.webp" alt="">
            </div>
            <img src="img/image3.webp" alt="" class="pic1">
            <img src="img/image4.webp" alt="" class="pic2">

            <div class="breadcrumbs">
                <div class="container">
                    <ul>
                        <li>
                            <a href="#">
                                Главная
                            </a>
                        </li>
                        <li><span>Кальянная</span></li>
                    </ul>
                </div>
            </div>

            <div class="block-hookah block2">
                <div class="container">
                    <div class="block-hookah__content">
                        <div class="block-hookah__left">
                            <div class="block-hookah__body">
                                <h2 class="title2">КаЛьянная</h2>
                                <p>
                                    Дым, еда и никакой спешки.
                                </p>
                                <div class="block-hookah__items">
                                    <div class="block-hookah__item">
                                        <img src="img/icons/hookah.svg" alt="" class="block-hookah__icon">
                                        <div class="block-hookah__titles">
                                            <span>Premium</span>
                                            <div class="block-hookah__title">
                                                50 руб.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="block-hookah__item">
                                        <img src="img/icons/hookah.svg" alt="" class="block-hookah__icon">
                                        <div class="block-hookah__titles">
                                            <span>Special</span>
                                            <div class="block-hookah__title">
                                                55 руб.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="block-hookah__item">
                                        <img src="img/icons/hookah.svg" alt="" class="block-hookah__icon">
                                        <div class="block-hookah__titles">
                                            <span>Грейпфрут</span>
                                            <div class="block-hookah__title">
                                                65 руб.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="block-hookah__item">
                                        <img src="img/icons/hookah.svg" alt="" class="block-hookah__icon">
                                        <div class="block-hookah__titles">
                                            <span>Авторский</span>
                                            <div class="block-hookah__title">
                                                95 руб.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="block-hookah__images">
                                <img src="img/image23.webp" alt="">
                                <img src="img/image23.webp" alt="">
                            </div>
                        </div>
                        <div class="block-hookah__right">
                            <img src="img/image23.webp" alt="">
                        </div>
                    </div>
                </div>
            </div>

            <div class="block-forms block2">
                <img loading="lazy" src="img/image5.webp" alt="" class="pic4">
                <img loading="lazy" src="img/image6.webp" alt="" class="pic5">
                <div class="container">
                    <div class="block-forms__content">
                        <img loading="lazy" src="img/image12.webp" alt="" class="block-forms__bg">
                        <form action="#" class="form">
                            <h2 class="title2">
                                Бронирование
                            </h2>
                            <div class="form__body">
                                <div class="form__inputs">
                                    <div class="form__input">
                                        <select name="form[]" class="select1">
                                            <option value="" data-show data-label data-label="Выберите дату:" selected>
                                                Выберите дату
                                            </option>
                                            <option value="1">Выберите дату1</option>
                                            <option value="2">Выберите дату2</option>
                                            <option value="3">Выберите дату3</option>
                                            <option value="4">Выберите дату4</option>
                                        </select>
                                    </div>
                                    <div class="form__input">
                                        <select name="form[]" class="select1">
                                            <option value="" data-show data-label data-label="Выберите дату:" selected>
                                                Выберите время
                                            </option>
                                            <option value="1">Выберите время1</option>
                                            <option value="2">Выберите время2</option>
                                            <option value="3">Выберите время3</option>
                                            <option value="4">Выберите время4</option>
                                        </select>
                                    </div>
                                    <div class="form__input">
                                        <input data-required autocomplete="off" type="text" name="form[]"
                                            placeholder="Ваше имя">
                                    </div>
                                    <div class="form__input">
                                        <input data-required autocomplete="off" type="text" name="form[]"
                                            placeholder="Ваш номер телефона">
                                    </div>
                                </div>
                                <div class="form__buttons">
                                    <label class="checkbox">
                                        <input data-required class="checkbox__input" type="checkbox" value="1"
                                            name="form[]">
                                        <span class="checkbox__label">
                                            <span class="checkbox__icon">
                                                <img loading="lazy" src="img/icons/check1.svg" alt="">
                                            </span>
                                            <span class="checkbox__text">Я даю согласие на обработку<br>
                                                персональных данных</span>
                                        </span>
                                    </label>
                                    <button type="submit" class="btn">
                                        <span>Отправить заявку</span>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </main>
        <footer class="footer">
            <img src="img/image16.webp" alt="" class="pic14">
            <div class="container">
                <div class="footer__content">
                    <div class="footer__top">
                        <a href="./" class="footer__logo">
                            <img loading="lazy" src="img/icons/logo3.svg" alt="">
                        </a>
                        <div class="footer__menu">
                            <ul>
                                <li>
                                    <a href="./">Главная</a>
                                </li>
                                <li>
                                    <a href="./">Меню</a>
                                </li>
                                <li>
                                    <a href="./">Кальянная</a>
                                </li>
                                <li>
                                    <a href="./">Вакансии</a>
                                </li>
                                <li>
                                    <a href="./">Контакты</a>
                                </li>
                            </ul>
                        </div>
                        <div class="socials">
                            <a href="./">
                                <img loading="lazy" src="img/icons/viber.svg" alt="">
                            </a>
                            <a href="./">
                                <img loading="lazy" src="img/icons/telegram.svg" alt="">
                            </a>
                            <a href="./">
                                <img loading="lazy" src="img/icons/instagram.svg" alt="">
                            </a>
                        </div>
                    </div>
                    <div class="footer__bottom">
                        <div class="footer__copy">
                            © Ресторан Омар Хайям
                        </div>
                        <a href="./" class="footer__link">
                            Политика конфиденциальности и согласие на обработку персональных данных
                        </a>
                        <a href="./" class="footer__logo2">
                            <img loading="lazy" src="img/icons/logo2.svg" alt="">
                        </a>
                    </div>
                </div>
            </div>
        </footer>
    </div>
    {% include 'blocks/popups.njk' %}
    {% include 'blocks/scripts.njk' %}
</body>

</html>